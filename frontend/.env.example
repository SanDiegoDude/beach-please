# Beach, Please frontend env.
# Copy to .env.local and uncomment to override. Defaults work for single-host
# dev (everything on the same machine).
#
# When you want phones / other devices on your home Wi-Fi to use the chat,
# set this to the LAN URL of the machine running the backend, e.g.:
#   NEXT_PUBLIC_BACKEND_URL=http://192.168.1.42:8765
#
# When unset, the client auto-derives the backend from window.location
# (assumes the backend is on the same host, port 8765).
#
# NEXT_PUBLIC_BACKEND_URL=http://192.168.1.42:8765
